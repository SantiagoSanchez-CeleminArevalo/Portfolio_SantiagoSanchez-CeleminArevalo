<Window
    x:Class="GesstiFFest.AddFestival"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:GesstiFFest"
    mc:Ignorable="d"
    Title="GesstiFFest Añadir Festival"
    WindowState="Normal"
    MinHeight="480"
    MinWidth="800" 
     ResizeMode="NoResize"
    FontWeight="Bold" Icon="/Fotos/Logo IPO.png" Topmost="True">
    <Grid>
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,5,0,0">
                <TextBlock Text="" Height="18"/>
                <TextBlock Text="DATOS FESTIVALES:"  />
                <TextBlock Text="" Height="18"/>
                <TextBlock Text="Nombre:" Height="22" />
                <TextBox Name="txtFestivalNombre" MaxLength="50" Height="26" Margin="0,5" TextChanged="txtFestivalNombre_TextChanged_1"/>
                
                <TextBlock Text="" Height="1"/>
                <TextBlock Text="Fecha:" Height="26" />
                <DatePicker x:Name="FechaSelect" Height="26" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" SelectedDateFormat="Short">
                    <DatePicker.CalendarStyle>
                        <Style/>
                    </DatePicker.CalendarStyle>
                </DatePicker>

                <TextBlock Text="" Height="7"/>
                <TextBlock Text="Precio General💲:" Height="20" />
                <TextBox x:Name="txtPrecioGeneral"  Margin ="0,5" Height="26" />

                <TextBlock Text="" Height="2"/>
                <TextBlock Text="Precio VIP💲:" Height="22" />
                <TextBox x:Name="txtPrecioVIP" Height="26" Margin ="0,5" />

                <TextBlock Text="" Height="2"/>
                <TextBlock Text="Estado:" Height="22" />
                <ComboBox x:Name="cmbEstado" Margin="0,5" Height="26">
                    <ComboBoxItem Content="Pendiente" />
                    <ComboBoxItem Content="Confirmado" />
                    <ComboBoxItem Content="Cancelado" />
                </ComboBox>


            </StackPanel>

            <StackPanel Grid.Column="2" Margin="0,5,0,0">
                <TextBlock Text="" Height="18"/>
                <TextBlock Text="REDES SOCIALES:"/>
                <TextBlock Text="" Height="18"/>
                <TextBlock Text="Instagram:" Height="22"/>
                <TextBox x:Name="txtInstagram" MaxLength="50" Height="26" TextChanged="txtInstagram_TextChanged"/>
                <TextBlock Text="" Height="2"/>
                <TextBlock Text="Facebook:" Height="22"/>
                <TextBox x:Name="txtFacebook" MaxLength="50" Height="26" Margin="0,5" TextChanged="txtFacebook_TextChanged"/>
                <TextBlock Text="Twitter:" Height="22"/>
                <TextBox x:Name="txtTwitter" MaxLength="50" Height="26" Margin="0,5" TextChanged="txtTwitter_TextChanged"/>
                
                <TextBlock Text="" Height="8"/>
                <TextBlock Text="Reglas 🚫:" Height="22"/>
                <TextBox x:Name="txtReglas"  Margin="0,0,0,0" FontSize="12" Height="35" TextChanged="txtReglas_TextChanged_2" SelectionTextBrush="Black" />

                <TextBlock Text="" Height="8"/>
                <TextBlock Text="Url Cartel:" Height="22"/>
                <TextBox x:Name="txtFoto" Margin="0,5,30,5" Height="26" Width="350"/>
                <Button Content="📎" FontSize="14" 
     Background= "#4CAF50"
     
     FontWeight="Bold" Click="CargarFoto_Click" Margin="330,-31,-2,5"/>

                
                
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="0,5,0,0">
                <TextBlock Text="" Height="18"/>
                <TextBlock Text="ESCENARIOS:" Margin="130,5,0,0" />
                <TextBlock Text="" Height="12"/>
                <TextBlock Text="Seleccione el/los escenarios para el festival:" Margin="55,0,0,0" />
                <TextBlock Text="" Height="18"/>
                <ListBox x:Name="lstEscenarios" 
                        Width="300" 
                        Height="170" 
                        SelectionMode="Multiple" 
                        Margin="-7" 
                         SelectionChanged="lstEscenarios_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>

                            <TextBlock Text="{Binding Nombre}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Image x:Name="Foto_escenario" 
                Source="/Logo IPO.png" 
                Width="150" 
                Height="130" 
                VerticalAlignment="Center" 
                Margin="0,-20,0,-90" 
                Stretch="UniformToFill" />
                <Button Content="Añadir" Width="209" Height="60" FontSize="16" Background="#4CAF50" Foreground="White" BorderBrush="#388E3C" BorderThickness="2" Click="Add_Click" Margin="0,0,0,-260" />

            </StackPanel>

        </Grid>
    </Grid>
</Window>
