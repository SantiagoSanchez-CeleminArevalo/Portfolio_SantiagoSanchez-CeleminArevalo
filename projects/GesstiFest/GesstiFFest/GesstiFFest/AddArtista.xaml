<Window x:Class="GesstiFFest.AddArtista"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GesstiFFest"
        mc:Ignorable="d"
         ResizeMode="NoResize"
        Title="GesstiFFest Añadir artista"  WindowState="Normal"  MinHeight="480" MinWidth="800" FontWeight="Bold" Icon="/Fotos/Logo IPO.png" Topmost="True">
    <Grid>

        <Grid Margin="10">
    
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

     
            <StackPanel Grid.Column="0" Margin="5">
                <TextBlock Text="DATOS FESTIVALES:"  />
                <TextBlock Text="" Height="18"/>
                <TextBlock Text="Festival:" Height="22" />
                <ComboBox x:Name="cmbFestivalesNombre"
                          Height="21"
          Width="360"
          SelectionChanged="cmbFestivalesNombre_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nombre}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="Fecha:" Height="20" />
                <ComboBox x:Name="cmbFestivalesFecha"
                          Height="22"
          Width="360"
          SelectionChanged="cmbFestivalesFecha_SelectionChanged">

                </ComboBox>

                <TextBlock Text="" Height="0"/>
                <TextBlock Text="DATOS ARTISTAS:" Height="15"/>
                <TextBlock Text="Nombre:" Height="18"/>
                <TextBox Name="txtNombreArtista" MaxLength="50" Height="22" Margin="0,5" TextChanged="txtNombreArtista_TextChanged"/>
                <TextBlock Text="" Height="1" RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleY="-1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock Text="Género ♀️ / ♂️:"/>

                <TextBox Name="txtGeneroArtista" MaxLength="30" Height="22" Margin="0,5" TextChanged="txtGeneroArtista_TextChanged"/>
                <TextBlock Text="" Height="1" RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleY="-1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock Text="Dirección:"/>
                <TextBox x:Name="txtDireccion" Margin="0,5"  Height="22" TextChanged="txtDireccion_TextChanged"/>
                <TextBlock Text="Teléfono ☎:"/>
                <TextBox x:Name="txtTelf" Margin="0,5" Height="22" TextChanged="txtTelf_TextChanged"/>
                <TextBlock Text="Correo 📧: "/>
                <TextBox x:Name="txtCorreo" Margin="0,5" Height="22" TextChanged="txtCorreo_TextChanged"/>
                <TextBlock Text="Imagen Artista:" Height="15"/>
                <TextBox x:Name="txtImagen" Margin="0,5,51,0" Height="22" TextChanged="txtImagen_TextChanged" Width="315"/>

                
                <TextBlock Text="Biografía:"/>
                <TextBox Name="txtBiografia" Margin="0,5" Height="50" TextChanged="txtBiografia_TextChanged"/>
                <TextBlock Text="" Height="3"/>
                
                
            </StackPanel>

         
            <StackPanel Grid.Column="1" Margin="5">
                <TextBlock Text="REDES SOCIALES:" Height="16"/>
                <TextBlock Text=""/>
                <TextBlock Text="Instagram:" Height="24"/>
                <TextBox x:Name="txtInsta" MaxLength="50" Height="22" TextChanged="txtInsta_TextChanged"/>
                <TextBlock Text="Facebook:" Height="14"/>
                <TextBox x:Name="txtFace" MaxLength="50" Height="22" Margin="0,5" TextChanged="txtFace_TextChanged"/>
                <TextBlock Text="Twitter:" Height="13"/>
                <TextBox x:Name="txtTwt" MaxLength="50" Height="22" Margin="0,5" TextChanged="txtTwt_TextChanged"/>
                <TextBlock Text="" Height="34" RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleY="-1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <Image x:Name="Foto_persona" 
                    Source="/Logo IPO.png" 
                    Width="150" 
                    Height="152" 
                    VerticalAlignment="Center" 
                    Margin="0,-40,10,10" 
                    Stretch="UniformToFill" />  
                <TextBlock Text="INFORMACIÓN CONTACTO:" Height="31"/>
                <TextBlock Text="Telefono Manager ☎ :"/>
                <TextBox Name="txttelfManager" MaxLength="30" Margin="0,5" Height="22" TextChanged="txttelfManager_TextChanged"/>
                <TextBlock Text="Correo Manager 📧:"/>
                <TextBox Name="txtCorreoManager" MaxLength="30" Margin="0,5" Height="22" TextChanged="txtCorreoManager_TextChanged"/>
                <TextBlock Text="Estado:"/>
                <ComboBox x:Name="cmbEstadoArtista" Width="360" Height="22" SelectionChanged="cmbEstadoArtista_SelectionChanged">
                    <ComboBoxItem Content="Pendiente"/>
                    <ComboBoxItem Content="Confirmado"/>
                    <ComboBoxItem Content="Cancelado"/>
                </ComboBox>

            </StackPanel>

            
            <StackPanel Grid.Column="2" Margin="5">
                <TextBlock Text="ESCENARIO:" Height="20"/>
                <TextBlock Text="" Height="12"/>
                <TextBlock Text="Nombre Escenario:" Height="23"/>
                <ComboBox x:Name="cmbEscenarios"
Width="360" Height="22"

SelectionChanged="cmbEscenarios_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                           
                            <TextBlock Text="{Binding Nombre}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="Hora Actuación🕓:" Height="15"/>
                <TextBox Name="txtHora" MaxLength="50" Height="22" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,5" TextChanged="txtHora_TextChanged"/>
                <TextBlock Text="" Height="40"/>
                <TextBlock Text="REQUISITOS:" Height="16"/>
                <TextBlock Text=""/>
                <TextBlock Text="Precio💲:" Height="22"/>
                <TextBox Name="txtPrecio" MaxLength="50" Height="22" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,2" TextChanged="txtPrecio_TextChanged"/>
                <TextBlock Text="Lugar Alojamiento🏨:" Height="15" Margin="0,-2"/>
                <TextBox Name="txtAlojamiento" MaxLength="50" Height="22" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,6" TextChanged="txtAlojamiento_TextChanged"/>
                <TextBlock Text="Peticiones Especiales✍🏻:" Height="20" Margin="0,-2"/>
                <TextBox Name="txtPeticiones" MaxLength="500" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="89" Margin="0,5" TextChanged="txtPeticiones_TextChanged"/>
                <TextBlock Text=""/>
                
                <TextBlock Text="" Height="20"/>
                <Button Content="Añadir" Margin="4" FontSize="14" 
        Height="50" Width="128" 
        Background="green" Foreground="White" 
        FontWeight="Bold" Click="Add_Click"/>
            </StackPanel>
        </Grid>
        <Button Content="📎" FontSize="14" 
                                Background= "#4CAF50"
                                
                                FontWeight="Bold" Click="CargarFoto_Click" Margin="327,413,760,119"/>
    </Grid>
</Window>
